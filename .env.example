#OpenAI
OPENAI_API_KEY=your_key

# gitリポジトリ（複数の場合はセミコロン区切り）
GIT_REPO_PATH=C:\Users\yourname\projects\app;C:\Users\yourname\projects\ml

# 出力先フォルダ
OUTPUT_DIR=C:\Users\yourname\Obsidian\Your_Vault\Daily_Summary

# 手動メモのフォルダ
NOTE_DIR=C:\Users\yourname\Obsidian\Your_Vault\Note

# 除外ドメイン（セミコロン区切り）。未設定の場合は除外なし。
EXCLUDED_DOMAINS=example.com;www.example.com
